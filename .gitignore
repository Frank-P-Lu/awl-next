/target
/gallery
/tmp
/dist

# --bench-suite's per-run output (the checked-in reference lives at
# benches/baseline.json; a fresh bench.json is scratch, never committed)
/bench.json
.claude/worktrees/
.playwright-mcp/

# site/check.html's data file — generated fresh at each deploy
# (.github/workflows/deploy-web.yml's "Write version.json" step), never
# committed. See site/README.md's "Check for updates" section.
/site/version.json

# Storyboard run outputs (`--storyboard`, default `<board>.run/` beside the
# .toml — see CAPTURE.md's storyboard section). The storyboards themselves
# (scenarios/*.toml + fixtures) are checked in; their runs never are.
*.run/
